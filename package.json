{
  "name": "moyu-xiuxian",
  "version": "3.7.0",
  "description": "大道三千，摸鱼为先 — 一款中国风修仙主题放置类 Web 游戏",
  "author": "gunlox",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gunlox/MoYuXiuXian.git"
  },
  "homepage": "https://github.com/gunlox/MoYuXiuXian",
  "keywords": ["idle-game", "cultivation", "xiuxian", "react", "typescript", "web-game"],
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "tsc -b && vite build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.jjboom.moyu-xiuxian",
    "productName": "摸鱼修仙",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN"
      ],
      "shortcutName": "摸鱼修仙"
    }
  }
}
